{
  "log": {"loglevel": "none"},
  "dns": {"servers": ["8.8.8.8", "1.1.1.1"]},
  "inbounds": [
    {
      "port": 10000,
      "listen": "127.0.0.1",
      "protocol": "trojan",
      "tag": "trojan",
      "settings": {
        "clients": [{"password": "saeka"}]
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": {"path": "/saeka-tojirp"},
        "sockopt": {
          "tcpFastOpen": true,
          "tcpNoDelay": true,
          "tcpKeepAliveInterval": 30
        }
      },
      "sniffing": {"enabled": true, "destOverride": ["http", "tls"]}
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct",
      "settings": {"domainStrategy": "UseIPv4"},
      "streamSettings": {
        "sockopt": {
          "tcpFastOpen": true,
          "tcpNoDelay": true,
          "tcpKeepAliveInterval": 30
        }
      }
    }
  ]
    }
